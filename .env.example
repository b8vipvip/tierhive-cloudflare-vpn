# =====================================
# VPS SSH
# =====================================
VPS_IP=139.99.123.120
SSH_PORT=22
SSH_USER=root
SSH_PASSWORD=CHANGE_ME

# =====================================
# Cloudflare
# =====================================
CF_API_TOKEN=CHANGE_ME
CF_ZONE_NAME=cn2.io

# 推荐填写，减少自动查询请求
CF_ACCOUNT_ID=
CF_ZONE_ID=

# =====================================
# Cloudflare API 网络
# =====================================
# 本地可以直连 Cloudflare API 时留空：
# CF_API_PROXY=
# 需要通过 v2rayN 时，例如：
CF_API_PROXY=http://127.0.0.1:10808

CF_API_TIMEOUT=60
CF_API_RETRIES=3
CF_API_RETRY_SLEEP=5

# =====================================
# 节点命名
# =====================================
NODE_NAME=sgp01
PROXY_SUBDOMAIN=sgp01
PANEL_SUBDOMAIN=sgp01p

# =====================================
# 3x-ui / Xray
# =====================================
PANEL_PORT=8888
INBOUND_PORT=10000
WS_PATH=abc123

XUI_USERNAME=admin
# 留空自动生成
XUI_PASSWORD=
# 留空自动生成隐藏路径
XUI_WEB_BASE_PATH=

# true：检测到已有 3x-ui 时，先备份再卸载重装
REINSTALL_3XUI=true

# =====================================
# VLESS
# =====================================
# 留空自动生成
VLESS_UUID=
VLESS_TEST_ATTEMPTS=2

# =====================================
# 行为控制
# =====================================
# true：不询问确认，直接运行
AUTO_YES=false
